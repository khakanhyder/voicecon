# ── Core ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your-very-long-random-secret-key-here

# ── Database (Railway MySQL) ───────────────────────────────────────────────────
# Railway sets this automatically when you add a MySQL service
DATABASE_URL=mysql://user:password@host:3306/railway

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Railway frontend URL
BACKEND_CORS_ORIGINS=["https://your-frontend.up.railway.app"]

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Powers team-invitation emails (and future transactional mail). Leave the SMTP
# fields blank in dev: with no provider configured the app uses a console
# provider that LOGS emails instead of sending — the invite flow still works.
#
# EMAIL_PROVIDER: auto (default) | smtp | sendgrid | console
#   auto → uses SMTP if SMTP_HOST is set, else SendGrid if SENDGRID_API_KEY is
#          set, else console (log-only). Set explicitly to force one.
EMAIL_PROVIDER=auto
# From identity used on all outbound mail.
EMAIL_FROM=no-reply@voicecon.app
EMAIL_FROM_NAME=Voicecon
# --- Option A: generic SMTP (works with Gmail, Mailgun, Postmark, SES, etc.) ---
# Port 587 = STARTTLS (SMTP_USE_TLS=true). Port 465 = implicit SSL (set
# SMTP_USE_SSL=true, SMTP_USE_TLS=false). Username/password are optional for
# relays that don't require auth.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# --- Option B: SendGrid API (alternative to SMTP) ---
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM_EMAIL=no-reply@voicecon.app

# ── Social Login (Google / Apple) ─────────────────────────────────────────────
# Public URL of the frontend (used as OAuth origin / Apple return base, and as
# the base for invitation Accept/Reject links — set this to your real frontend).
FRONTEND_URL=https://your-frontend.up.railway.app
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Apple Developer → Certificates, IDs & Profiles. APPLE_CLIENT_ID is the Services ID
# (e.g. com.voicecon.web). TEAM_ID/KEY_ID/PRIVATE_KEY are only needed for the
# authorization-code exchange; pure sign-in verification needs only APPLE_CLIENT_ID.
APPLE_CLIENT_ID=com.yourcompany.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...

# ── Telephony (optional) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# For local/dev use the TEST keys (sk_test_…, pk_test_…). Replace with LIVE keys
# (sk_live_…, pk_live_…) in production.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook signing secret from https://dashboard.stripe.com/webhooks (whsec_…)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Mailchimp (Launching-Soon waitlist) ─────────────────────────────────────
# API key: Mailchimp → Account & billing → Extras → API keys (ends in -usXX).
MAILCHIMP_API_KEY=your_mailchimp_api_key_here-us21
# Audience (List) ID: Audience → Settings → Audience name and defaults → Audience ID.
MAILCHIMP_AUDIENCE_ID=your_audience_id_here
# Optional — auto-derived from the API key's -usXX suffix if left blank.
MAILCHIMP_SERVER_PREFIX=
