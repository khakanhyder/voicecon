# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Stripe (publishable key — pk_test_… for dev, pk_live_… for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Social login (public identifiers only — safe to expose in the browser)
# Google OAuth 2.0 Web client ID (same value as backend GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Apple Services ID + the return URL registered in the Apple Developer portal.
# Apple requires an https domain — it does NOT work on http/localhost.
NEXT_PUBLIC_APPLE_CLIENT_ID=com.yourcompany.web
NEXT_PUBLIC_APPLE_REDIRECT_URI=https://your-frontend-domain.com/login

# App Configuration
NEXT_PUBLIC_APP_NAME=Voicecon
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false

# Optional: Sentry Configuration (for error tracking in production)
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
